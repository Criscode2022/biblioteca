# ---------------------------------------------------------------------------
# Optional cloud mode (Neon Auth + Neon Data API).
#
# Leave these unset to run the app fully offline (localStorage). Set ALL THREE
# to enable the "Nube" mode toggle with login/register and per-user books.
# Copy this file to `.env.local` and fill in the values from the Neon console.
# ---------------------------------------------------------------------------

# Neon Auth (Stack) — Project settings → Neon Auth
VITE_STACK_PROJECT_ID=
VITE_STACK_PUBLISHABLE_CLIENT_KEY=

# Neon Data API — Project settings → Data API (PostgREST endpoint URL)
VITE_NEON_DATA_API_URL=

# ---------------------------------------------------------------------------
# AI backend (Netlify Functions). Server-side only — never exposed to the
# browser. Required for the AI features (analysis, semantic search, RAG).
# On Netlify set these in Site configuration → Environment variables.
# Locally, run `netlify dev` so the functions can read them.
# ---------------------------------------------------------------------------

# Neon direct connection string (Neon console → Connect). Used by the
# functions for pgvector queries; RLS does not apply to this connection,
# ownership is enforced in every query.
DATABASE_URL=

# OpenAI (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Optional model overrides
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Server-side copy of the Stack project id for JWT verification.
# Falls back to VITE_STACK_PROJECT_ID if unset.
# STACK_PROJECT_ID=
