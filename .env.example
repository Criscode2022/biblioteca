# ---------------------------------------------------------------------------
# Optional cloud mode (Neon Auth + Neon Data API).
#
# Leave these unset to run the app fully offline (localStorage). Set ALL THREE
# to enable the "Nube" mode toggle with login/register and per-user books.
# Copy this file to `.env.local` and fill in the values from the Neon console.
# ---------------------------------------------------------------------------

# Neon Auth (Stack) — Project settings → Neon Auth
VITE_STACK_PROJECT_ID=
VITE_STACK_PUBLISHABLE_CLIENT_KEY=

# Neon Data API — Project settings → Data API (PostgREST endpoint URL)
VITE_NEON_DATA_API_URL=
