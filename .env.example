# ---------------------------------------------------------------------------
# Optional cloud mode (Neon Auth + Neon Data API).
#
# Leave these unset to run the app fully offline (localStorage). Set BOTH
# to enable the "Nube" mode toggle with login/register and per-user books.
# Copy this file to `.env.local` and fill in the values from the Neon console.
# ---------------------------------------------------------------------------

# Neon Auth — Project → Auth → Configuration (Auth URL / base URL)
VITE_NEON_AUTH_URL=

# Neon Data API — Project → Data API (REST endpoint URL)
VITE_NEON_DATA_API_URL=
